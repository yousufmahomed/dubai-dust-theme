{%- comment -%}
  Product Grid Section — can be used on homepage or collection pages
{%- endcomment -%}

<section class="section-padding">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="section-header">
        {%- if section.settings.tagline != blank -%}
          <p class="tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}
        <h2><span class="gold-gradient">{{ section.settings.heading }}</span></h2>
      </div>
    {%- endif -%}

    <div class="product-grid">
      {%- assign selected_collection = collections[section.settings.collection] -%}
      {%- if selected_collection != blank -%}
        {%- for product in selected_collection.products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Show recent products as fallback {%- endcomment -%}
        {%- for product in collections.all.products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all and selected_collection != blank -%}
      <div class="text-center mt-4">
        <a href="{{ selected_collection.url }}" class="btn btn-outline">View All {{ selected_collection.title }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product Grid",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Trending Now"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to Show",
      "min": 2,
      "max": 24,
      "step": 2,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All Button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Product Grid"
    }
  ]
}
{% endschema %}
