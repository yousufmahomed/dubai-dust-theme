{%- comment -%}
  Site Footer
{%- endcomment -%}

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">
      {%- comment -%} Brand Column {%- endcomment -%}
      <div class="footer-brand">
        <div class="footer-brand__name">
          <span class="gold-gradient">{{ settings.brand_name | default: 'Dubai Dust' }}</span>
        </div>
        <p class="footer-brand__tagline">{{ settings.brand_tagline | default: 'Luxury Within Reach' }}</p>
        <p class="footer-brand__description">
          {{ section.settings.footer_description | default: 'Your premier destination for accessible luxury. Curated collections from the world&rsquo;s finest brands, delivered to your doorstep across South Africa.' }}
        </p>

        {%- comment -%} Social Icons {%- endcomment -%}
        <div class="footer-social">
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok != blank -%}
            <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_whatsapp != blank -%}
            <a href="https://wa.me/{{ settings.social_whatsapp | remove: '+' | remove: ' ' }}" target="_blank" rel="noopener" aria-label="WhatsApp">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Shop Column {%- endcomment -%}
      <div class="footer-col">
        <h4 class="footer-col__title">Shop</h4>
        <a href="/collections" class="footer-col__link">All Collections</a>
        <a href="/collections/cosmetics" class="footer-col__link">Cosmetics</a>
        <a href="/collections/jewellery" class="footer-col__link">Jewellery</a>
        <a href="/collections/perfume" class="footer-col__link">Perfume</a>
        <a href="/collections/handbags" class="footer-col__link">Handbags</a>
        <a href="/collections/watches" class="footer-col__link">Watches</a>
      </div>

      {%- comment -%} Customer Care Column {%- endcomment -%}
      <div class="footer-col">
        <h4 class="footer-col__title">Customer Care</h4>
        <a href="/pages/contact" class="footer-col__link">Contact Us</a>
        <a href="/pages/shipping-policy" class="footer-col__link">Shipping Policy</a>
        <a href="/pages/returns-policy" class="footer-col__link">Returns &amp; Refunds</a>
        <a href="/pages/faq" class="footer-col__link">FAQ</a>
        <a href="/account" class="footer-col__link">My Account</a>
      </div>

      {%- comment -%} Legal Column {%- endcomment -%}
      <div class="footer-col">
        <h4 class="footer-col__title">Legal</h4>
        <a href="/policies/privacy-policy" class="footer-col__link">Privacy Policy</a>
        <a href="/policies/terms-of-service" class="footer-col__link">Terms &amp; Conditions</a>
        <a href="/pages/disclaimer" class="footer-col__link">Disclaimer</a>
        <a href="/policies/refund-policy" class="footer-col__link">Refund Policy</a>
      </div>
    </div>

    <div class="ornament-divider"></div>

    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <p style="margin-top: 4px; font-size: 0.6875rem;">Newcastle, KwaZulu-Natal, South Africa &bull; Powered by Shopify</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "footer_description",
      "label": "Footer Description",
      "default": "Your premier destination for accessible luxury. Curated collections from the world's finest brands, delivered to your doorstep across South Africa."
    }
  ]
}
{% endschema %}
