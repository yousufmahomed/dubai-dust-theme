# ============================================================================
# Dubai Dust — Ultra-Luxury Email Webhook Handler
# Copy this file to .env and fill in your values
# ============================================================================

# ── Shopify Webhook Verification ──
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_secret_here

# ── Email Provider (choose one: sendgrid | mailgun | postmark) ──
EMAIL_PROVIDER=sendgrid

# ── API Key for your chosen email provider ──
# SendGrid: starts with SG.
# Mailgun:  starts with key-
# Postmark: UUID format
EMAIL_API_KEY=your_email_api_key_here

# ── Sender Address ──
EMAIL_FROM=Dubai Dust Concierge <concierge@dubaidust.co.za>

# ── Mailgun Only ──
MAILGUN_DOMAIN=mg.dubaidust.co.za

# ── Application ──
PORT=3500
SHOP_URL=https://dubaidust.co.za
NODE_ENV=production
