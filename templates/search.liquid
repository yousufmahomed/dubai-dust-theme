{%- comment -%} Search Results Template {%- endcomment -%}

<div class="page-template">
  <div class="container">
    <div class="section-header">
      <h1><span class="gold-gradient">Search</span></h1>
    </div>

    <form action="/search" method="get" style="max-width: 600px; margin: 0 auto 48px;">
      <div style="display: flex; gap: 12px;">
        <input
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="Search for luxury products..."
          style="flex: 1; padding: 14px 20px; background: rgba(255,255,255,0.05); border: 1px solid rgba(212,168,83,0.2); border-radius: 6px; color: var(--color-text); font-size: 0.9375rem;"
        >
        <button type="submit" class="btn btn-primary">Search</button>
      </div>
    </form>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <p class="text-center text-muted mb-4">{{ search.results_count }} results for "{{ search.terms }}"</p>
        <div class="product-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'product-card', product: item %}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="text-center" style="padding: 48px 0;">
          <p style="font-size: 2rem; margin-bottom: 12px;">✦</p>
          <h3>No results found</h3>
          <p class="text-muted">Try a different search term or browse our <a href="/collections">collections</a>.</p>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>
