{%- comment -%}
  Cart Page Template
{%- endcomment -%}

<div class="page-template">
  <div class="container container--narrow">
    <h1 class="text-center"><span class="gold-gradient">Your Cart</span></h1>

    {%- if cart.item_count > 0 -%}
      <div class="glass-card">
        {%- for item in cart.items -%}
          <div class="cart-item" style="padding: 20px 0; {% unless forloop.last %}border-bottom: 1px solid rgba(212,168,83,0.08);{% endunless %}">
            <div style="display: flex; gap: 20px; align-items: center;">
              <div style="width: 100px; height: 100px; border-radius: 8px; overflow: hidden; flex-shrink: 0; background: #111528;">
                {%- if item.image -%}
                  <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" style="width:100%;height:100%;object-fit:cover;">
                {%- endif -%}
              </div>
              <div style="flex: 1;">
                <h4 style="margin-bottom: 4px; font-size: 1rem;">
                  <a href="{{ item.url }}">{{ item.product.title }}</a>
                </h4>
                {%- if item.variant.title != 'Default Title' -%}
                  <p style="font-size: 0.8125rem; color: var(--color-text-muted); margin-bottom: 4px;">{{ item.variant.title }}</p>
                {%- endif -%}
                <p style="font-size: 0.8125rem; color: var(--color-text-muted);">Qty: {{ item.quantity }}</p>
                {%- if item.properties.size > 0 -%}
                  {%- for property in item.properties -%}
                    {%- unless property.first contains '_' -%}
                      <p style="font-size: 0.75rem; color: var(--color-text-muted); margin-top: 4px;">
                        <strong>{{ property.first }}:</strong> {{ property.last }}
                      </p>
                    {%- endunless -%}
                  {%- endfor -%}
                {%- endif -%}
              </div>
              <div style="text-align: right;">
                <p style="font-family: var(--font-heading); font-size: 1.125rem; color: var(--color-gold); font-weight: 700;">
                  {{ item.final_line_price | money }}
                </p>
                <a href="/cart/change?line={{ forloop.index }}&quantity=0"
                   style="font-size: 0.75rem; color: var(--color-text-muted); margin-top: 8px; display: inline-block;">
                  Remove
                </a>
              </div>
            </div>
          </div>
        {%- endfor -%}

        <div style="border-top: 1px solid rgba(212,168,83,0.15); padding-top: 24px; margin-top: 8px;">
          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 16px;">
            <span style="font-size: 1.125rem; font-weight: 600;">Subtotal</span>
            <span style="font-family: var(--font-heading); font-size: 1.5rem; color: var(--color-gold); font-weight: 700;">{{ cart.total_price | money }}</span>
          </div>
          <p style="font-size: 0.8125rem; color: var(--color-text-muted); margin-bottom: 24px;">
            Shipping &amp; taxes calculated at checkout
          </p>
          <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <a href="/checkout" class="btn btn-primary btn-lg" style="flex: 1;">Proceed to Checkout</a>
            <a href="/collections" class="btn btn-outline" style="flex: 0;">Continue Shopping</a>
          </div>
        </div>
      </div>
    {%- else -%}
      <div class="glass-card text-center" style="padding: 80px 32px;">
        <p style="font-size: 3rem; margin-bottom: 16px;">✦</p>
        <h3>Your cart is empty</h3>
        <p class="text-muted" style="margin-bottom: 24px;">Discover luxury within reach — browse our collections.</p>
        <a href="/collections" class="btn btn-primary">Shop Collections</a>
      </div>
    {%- endif -%}
  </div>
</div>
