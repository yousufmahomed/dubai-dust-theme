{%- comment -%}
  Homepage Template
  templates/index.liquid
{%- endcomment -%}

{% section 'hero' %}

<div class="ornament-divider"></div>

{% section 'featured-collections' %}

{% section 'product-grid' %}

{%- comment -%} Value Proposition Section {%- endcomment -%}
<section class="section-padding" style="border-top: 1px solid rgba(212,168,83,0.05);">
  <div class="container">
    <div class="section-header">
      <p class="tagline">Why Dubai Dust?</p>
      <h2><span class="gold-gradient">The Dubai Dust Promise</span></h2>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 32px;">
      <div class="glass-card text-center">
        <p style="font-size: 2rem; margin-bottom: 12px;">✨</p>
        <h4>Authentic Luxury</h4>
        <p class="text-muted" style="font-size: 0.875rem;">Every product sourced from verified South African suppliers. Genuine brands, guaranteed.</p>
      </div>
      <div class="glass-card text-center">
        <p style="font-size: 2rem; margin-bottom: 12px;">🚚</p>
        <h4>Nationwide Delivery</h4>
        <p class="text-muted" style="font-size: 0.875rem;">2–5 business days across South Africa. Free shipping on orders over R2,000.</p>
      </div>
      <div class="glass-card text-center">
        <p style="font-size: 2rem; margin-bottom: 12px;">👑</p>
        <h4>VIP Experience</h4>
        <p class="text-muted" style="font-size: 0.875rem;">Ultra-luxury collections with exclusive access, surprise benefits, and white-glove service.</p>
      </div>
      <div class="glass-card text-center">
        <p style="font-size: 2rem; margin-bottom: 12px;">🔒</p>
        <h4>Secure Payments</h4>
        <p class="text-muted" style="font-size: 0.875rem;">Powered by Yoco — South Africa's trusted payment gateway. Your data is safe.</p>
      </div>
    </div>
  </div>
</section>
