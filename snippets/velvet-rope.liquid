{% comment %}
  Velvet Rope - Exclusive Access Gate
  Two tiers:
  1. Standard Luxury: Jewellery, Perfume, Men's/Ladies' Watches - 25th visit, ~90-110s wait
  2. Ultra Luxury: All Ultra Luxury collections - EVERY visit, ~180s wait, R250 ONCE-OFF VIP deposit (lifetime access), AI concierge mention
{% endcomment %}

{% assign standard_velvet = 'jewellery,perfume,mens-luxury-watches,ladies-luxury-watches' | split: ',' %}
{% assign ultra_velvet = 'ultra-luxury-mens-watches,ultra-luxury-ladies-watches,ultra-luxury-jewellery,ultra-luxury-cosmetics,ultra-luxury-perfume,ultra-luxury-electronics,ultra-luxury-accessories,ultra-luxury-handbags' | split: ',' %}

{% assign is_standard = false %}
{% assign is_ultra = false %}

{% for vc in standard_velvet %}
  {% if collection.handle == vc %}
    {% assign is_standard = true %}
  {% endif %}
{% endfor %}

{% for uc in ultra_velvet %}
  {% if collection.handle == uc %}
    {% assign is_ultra = true %}
  {% endif %}
{% endfor %}

{% if is_standard or is_ultra %}
<div id="velvet-rope-overlay" style="display:none;" data-tier="{{ is_ultra | default: false }}">
  <div class="velvet-backdrop"></div>
  <div class="velvet-modal {% if is_ultra %}velvet-ultra{% endif %}">
    {% if is_ultra %}
    <!-- Ultra Luxury Tier -->
    <div class="velvet-crown">
      <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#d4a853" stroke-width="1.2">
        <path d="M2 17L5 7L9 12L12 4L15 12L19 7L22 17H2Z" fill="rgba(212,168,83,0.15)"/>
        <path d="M2 17L5 7L9 12L12 4L15 12L19 7L22 17H2Z"/>
        <circle cx="5" cy="7" r="1" fill="#d4a853"/>
        <circle cx="12" cy="4" r="1" fill="#d4a853"/>
        <circle cx="19" cy="7" r="1" fill="#d4a853"/>
      </svg>
    </div>
    <div class="velvet-ultra-badge">ULTRA LUXURY</div>
    <h2 class="velvet-title">Private Viewing Room</h2>
    <p class="velvet-subtitle">{{ collection.title }}</p>
    <div class="velvet-divider velvet-divider-ultra"></div>
    <p class="velvet-message">
      Welcome to the Dubai Dust <span class="velvet-gold">Private Collection</span>.
      <br>You are guest <span id="velvet-guest-number" class="velvet-gold">3</span> awaiting entry.
    </p>
    <div class="velvet-vip-notice">
      <div class="velvet-vip-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d4a853" stroke-width="1.5">
          <rect x="2" y="6" width="20" height="14" rx="2"/>
          <path d="M22 10H2"/>
          <path d="M6 14H10"/>
        </svg>
      </div>
      <p class="velvet-vip-text">
        A <span class="velvet-gold">once-off R250 VIP viewing deposit</span> applies — pay once, enjoy lifetime access to all Ultra Luxury collections.
        <br><span style="font-size:11px;opacity:0.7;">Fully redeemable against your purchase. Refunded if you choose not to buy.</span>
      </p>
    </div>
    <div class="velvet-timer-wrap">
      <div class="velvet-timer-label">Preparing your private viewing</div>
      <div id="velvet-countdown" class="velvet-countdown">5:00</div>
      <div class="velvet-progress-track">
        <div id="velvet-progress-bar" class="velvet-progress-fill velvet-progress-ultra"></div>
      </div>
    </div>
    <div class="velvet-concierge-notice">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d4a853" stroke-width="1.5">
        <circle cx="12" cy="12" r="10"/>
        <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
        <line x1="9" y1="9" x2="9.01" y2="9"/>
        <line x1="15" y1="9" x2="15.01" y2="9"/>
      </svg>
      <span>Your personal AI Shopping Concierge will be available inside</span>
    </div>
    <p class="velvet-footnote">Ultra luxury demands patience. The extraordinary awaits.</p>

    {% else %}
    <!-- Standard Luxury Tier -->
    <div class="velvet-icon">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#d4a853" stroke-width="1.5">
        <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
      </svg>
    </div>
    <h2 class="velvet-title">Exclusive Collection</h2>
    <p class="velvet-subtitle">{{ collection.title }}</p>
    <div class="velvet-divider"></div>
    <p class="velvet-message">
      You are guest <span id="velvet-guest-number" class="velvet-gold">6</span> waiting to enter.
      <br>Please allow our <span class="velvet-gold">5 current customers</span> to conclude their shopping.
    </p>
    <div class="velvet-timer-wrap">
      <div class="velvet-timer-label">Estimated wait time</div>
      <div id="velvet-countdown" class="velvet-countdown">5:00</div>
      <div class="velvet-progress-track">
        <div id="velvet-progress-bar" class="velvet-progress-fill"></div>
      </div>
    </div>
    <p class="velvet-footnote">Thank you for your patience. Luxury is worth the wait.</p>
    {% endif %}
  </div>
</div>

<style>
  .velvet-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(5, 7, 15, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 99998;
  }
  .velvet-modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 99999;
    background: linear-gradient(145deg, #0d1117 0%, #131920 50%, #0d1117 100%);
    border: 1px solid rgba(212, 168, 83, 0.3);
    border-radius: 16px;
    padding: 48px 40px;
    max-width: 480px;
    width: 90%;
    text-align: center;
    box-shadow: 0 0 60px rgba(212, 168, 83, 0.08), 0 0 120px rgba(0,0,0,0.5);
    animation: velvetFadeIn 0.8s ease;
  }
  .velvet-modal.velvet-ultra {
    max-width: 520px;
    border: 1px solid rgba(212, 168, 83, 0.5);
    box-shadow: 0 0 80px rgba(212, 168, 83, 0.15), 0 0 160px rgba(0,0,0,0.6),
                inset 0 0 60px rgba(212, 168, 83, 0.03);
    background: linear-gradient(145deg, #0a0d14 0%, #10151d 30%, #0d1219 60%, #0a0d14 100%);
  }
  @keyframes velvetFadeIn {
    from { opacity: 0; transform: translate(-50%, -50%) scale(0.95); }
    to { opacity: 1; transform: translate(-50%, -50%) scale(1); }
  }
  .velvet-icon, .velvet-crown {
    margin-bottom: 20px;
    animation: velvetPulse 2s ease-in-out infinite;
  }
  @keyframes velvetPulse {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1); }
  }
  .velvet-ultra-badge {
    display: inline-block;
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 4px;
    color: #0a0e1a;
    background: linear-gradient(135deg, #d4a853, #f0d48a, #d4a853);
    padding: 4px 20px;
    border-radius: 20px;
    margin-bottom: 20px;
    text-transform: uppercase;
  }
  .velvet-title {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 600;
    color: #d4a853;
    margin: 0 0 8px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .velvet-subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    margin: 0 0 24px;
    text-transform: uppercase;
    letter-spacing: 3px;
  }
  .velvet-divider {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #d4a853, transparent);
    margin: 0 auto 24px;
  }
  .velvet-divider-ultra {
    width: 100px;
    height: 2px;
    background: linear-gradient(90deg, transparent, #d4a853, #f0d48a, #d4a853, transparent);
  }
  .velvet-message {
    font-family: 'Montserrat', sans-serif;
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255,255,255,0.75);
    margin: 0 0 24px;
  }
  .velvet-gold {
    color: #d4a853;
    font-weight: 600;
  }
  .velvet-vip-notice {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: rgba(212, 168, 83, 0.06);
    border: 1px solid rgba(212, 168, 83, 0.15);
    border-radius: 10px;
    padding: 16px;
    margin-bottom: 24px;
    text-align: left;
  }
  .velvet-vip-icon {
    flex-shrink: 0;
    margin-top: 2px;
  }
  .velvet-vip-text {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255,255,255,0.8);
    margin: 0;
  }
  .velvet-timer-wrap {
    margin-bottom: 20px;
  }
  .velvet-timer-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.4);
    margin-bottom: 8px;
  }
  .velvet-countdown {
    font-family: 'Playfair Display', serif;
    font-size: 48px;
    font-weight: 700;
    color: #d4a853;
    margin-bottom: 16px;
    text-shadow: 0 0 20px rgba(212, 168, 83, 0.3);
  }
  .velvet-progress-track {
    width: 100%;
    height: 3px;
    background: rgba(255,255,255,0.1);
    border-radius: 3px;
    overflow: hidden;
  }
  .velvet-progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #d4a853, #f0d48a);
    border-radius: 3px;
    transition: width 1s linear;
  }
  .velvet-progress-ultra {
    background: linear-gradient(90deg, #b8860b, #d4a853, #f0d48a, #d4a853);
    background-size: 200% 100%;
    animation: shimmerGold 3s ease infinite;
  }
  @keyframes shimmerGold {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
  .velvet-concierge-notice {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 16px;
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    color: rgba(212, 168, 83, 0.7);
    letter-spacing: 0.5px;
  }
  .velvet-footnote {
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    color: rgba(255,255,255,0.3);
    font-style: italic;
    margin: 0;
  }
  @media (max-width: 480px) {
    .velvet-modal {
      padding: 36px 24px;
    }
    .velvet-title {
      font-size: 22px;
    }
    .velvet-countdown {
      font-size: 36px;
    }
    .velvet-vip-notice {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>

<script>
(function() {
  var IS_ULTRA = {{ is_ultra }};
  var COLLECTION = '{{ collection.handle }}';
  var overlay = document.getElementById('velvet-rope-overlay');
  if (!overlay) return;

  if (IS_ULTRA) {
    // Ultra Luxury: show on EVERY visit, wait ~180 seconds
    overlay.style.display = 'block';
    document.body.style.overflow = 'hidden';

    var guestNum = Math.floor(Math.random() * 3) + 2; // 2-4 guests (exclusive)
    var guestEl = document.getElementById('velvet-guest-number');
    if (guestEl) guestEl.textContent = guestNum;

    var totalWait = Math.floor(Math.random() * 21) + 170; // 170-190 seconds (~3 min)
    var elapsed = 0;
    var displayTotal = 300;
    var countdownEl = document.getElementById('velvet-countdown');
    var progressBar = document.getElementById('velvet-progress-bar');

    var timer = setInterval(function() {
      elapsed++;
      var ratio = elapsed / totalWait;
      var displayRemaining = Math.max(0, Math.ceil(displayTotal * (1 - ratio)));
      var mins = Math.floor(displayRemaining / 60);
      var secs = displayRemaining % 60;
      if (countdownEl) countdownEl.textContent = mins + ':' + (secs < 10 ? '0' : '') + secs;
      if (progressBar) progressBar.style.width = (ratio * 100) + '%';

      if (elapsed >= totalWait) {
        clearInterval(timer);
        if (countdownEl) countdownEl.textContent = '0:00';
        if (progressBar) progressBar.style.width = '100%';
        overlay.style.transition = 'opacity 0.8s ease';
        overlay.style.opacity = '0';
        setTimeout(function() {
          overlay.style.display = 'none';
          document.body.style.overflow = '';
        }, 800);
      }
    }, 1000);

  } else {
    // Standard Luxury: trigger every 25th visit, ~90-110s wait
    var TRIGGER_EVERY = 25;
    var storageKey = 'dd_vr_' + COLLECTION;
    var visits = parseInt(localStorage.getItem(storageKey) || '0', 10);
    visits++;
    localStorage.setItem(storageKey, visits.toString());

    if (visits % TRIGGER_EVERY !== 0) return;

    overlay.style.display = 'block';
    document.body.style.overflow = 'hidden';

    var guestNum = Math.floor(Math.random() * 5) + 5;
    var guestEl = document.getElementById('velvet-guest-number');
    if (guestEl) guestEl.textContent = guestNum;

    var totalWait = Math.floor(Math.random() * 21) + 90;
    var elapsed = 0;
    var displayTotal = 300;
    var countdownEl = document.getElementById('velvet-countdown');
    var progressBar = document.getElementById('velvet-progress-bar');

    var timer = setInterval(function() {
      elapsed++;
      var ratio = elapsed / totalWait;
      var displayRemaining = Math.max(0, Math.ceil(displayTotal * (1 - ratio)));
      var mins = Math.floor(displayRemaining / 60);
      var secs = displayRemaining % 60;
      if (countdownEl) countdownEl.textContent = mins + ':' + (secs < 10 ? '0' : '') + secs;
      if (progressBar) progressBar.style.width = (ratio * 100) + '%';

      if (elapsed >= totalWait) {
        clearInterval(timer);
        if (countdownEl) countdownEl.textContent = '0:00';
        if (progressBar) progressBar.style.width = '100%';
        overlay.style.transition = 'opacity 0.8s ease';
        overlay.style.opacity = '0';
        setTimeout(function() {
          overlay.style.display = 'none';
          document.body.style.overflow = '';
        }, 800);
      }
    }, 1000);
  }
})();
</script>
{% endif %}
